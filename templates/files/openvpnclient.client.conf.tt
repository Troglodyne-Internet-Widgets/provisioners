client
dev tun
proto [% proto %]

remote [% server %] [% port %]
resolv-retry infinite
nobind

persist-key
persist-tun

ca   /etc/openvpn/client/ca.crt
cert /etc/openvpn/client/client.crt
key  /etc/openvpn/client/client.key

tls-auth /etc/openvpn/client/ta.key 1
tls-version-min 1.2

cipher [% cipher %]
auth SHA256

verb 3
log-append /var/log/openvpn/openvpn-client.log
