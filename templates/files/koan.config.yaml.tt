# Generated by Provisioner::Recipe::koan.
# Behavioural settings — secrets live in ../.env.

max_runs_per_day: [% max_runs_per_day %]
interval_seconds: [% interval_seconds %]

# Boot into pause so the bot waits for an explicit /resume before
# touching anything — useful for scheduled launches and re-provisions.
start_on_pause: [% start_on_pause ? 'true' : 'false' %]

# Focus mode: when true, only run explicitly queued missions (no
# autonomous exploration).  Defaults off so the bot acts on its own.
focus: [% focus ? 'true' : 'false' %]

messaging:
  provider: "[% messaging_provider %]"
[% IF messaging_provider == 'matrix' %]
  matrix:
    homeserver:   "[% matrix_homeserver %]"
    user_id:      "[% matrix_user_id %]"
    room_id:      "[% matrix_room_id %]"
[% IF matrix_e2ee %]
    e2ee:         true
[% ELSE %]
    e2ee:         false
[% END %]
[% IF matrix_access_token %]
    access_token: "[% matrix_access_token %]"
[% IF matrix_device_id %]
    device_id:    "[% matrix_device_id %]"
[% END %]
[% END %]
    # When the bootstrap (matrix_password) path is used, access_token and
    # device_id are loaded at runtime from instance/matrix/credentials.env.
[% END %]

github:
  nickname: "[% github_nickname %]"
  commands_enabled: true
[% IF github_authorized_users.size() %]
  authorized_users:
[% FOR u IN github_authorized_users %]
    - "[% u %]"
[% END %]
[% END %]

[% IF smtp_host %]
email:
  enabled: true
  max_per_day: 5
[% END %]
