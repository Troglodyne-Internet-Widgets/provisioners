# Generated by Provisioner::Recipe::koan.
# Project registry for the bot.  Add/edit projects in the [koan] block
# of recipes.yaml — this file is regenerated on every re-provision.

defaults:
  git_auto_merge:
    enabled: false
    base_branch: "main"
    strategy: "squash"

projects:
[% FOR name IN projects.keys().sort() %]
[% p = projects.$name %]
  [% name %]:
    path: "[% p.path %]"
[% IF p.cli_provider %]
    cli_provider: "[% p.cli_provider %]"
[% END %]
[% IF p.github_url %]
    github_url: "[% p.github_url %]"
[% END %]
[% IF p.base_branch %]
    git_auto_merge:
      base_branch: "[% p.base_branch %]"
[% END %]
[% END %]
