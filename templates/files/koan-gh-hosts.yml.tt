# Generated by Provisioner::Recipe::koan — pre-seeds gh's auth state so
# `gh repo clone`, `gh api`, etc. work without running `gh auth login`
# (which is interactive and useless on an unattended bot).  Token here
# matches GH_TOKEN in the rendered .env, so the bot has a single source
# of truth that we just replicate into the spot gh looks for it.
github.com:
    git_protocol: [% github_ssh_privkey ? 'ssh' : 'https' %]
    user: [% github_user %]
    oauth_token: [% github_token %]
