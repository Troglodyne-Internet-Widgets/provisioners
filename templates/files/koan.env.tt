# Generated by Provisioner::Recipe::koan — do not edit by hand.
KOAN_ROOT=[% install_dir %]/[% domain %]/koan
KOAN_EMAIL=[% koan_email %]

KOAN_MESSAGING_PROVIDER=[% messaging_provider %]
[% IF messaging_provider == 'telegram' %]
KOAN_TELEGRAM_TOKEN=[% telegram_token %]
KOAN_TELEGRAM_CHAT_ID=[% telegram_chat_id %]
[% END %]
[% IF messaging_provider == 'slack' %]
KOAN_SLACK_BOT_TOKEN=[% slack_bot_token %]
KOAN_SLACK_APP_TOKEN=[% slack_app_token %]
KOAN_SLACK_CHANNEL_ID=[% slack_channel_id %]
[% END %]
[% IF messaging_provider == 'matrix' %]
KOAN_MATRIX_HOMESERVER=[% matrix_homeserver %]
KOAN_MATRIX_USER_ID=[% matrix_user_id %]
KOAN_MATRIX_ROOM_ID=[% matrix_room_id %]
[% IF matrix_e2ee %]
KOAN_MATRIX_E2EE=1
KOAN_MATRIX_PICKLE_KEY=[% matrix_pickle_key %]
[% ELSE %]
KOAN_MATRIX_E2EE=0
[% END %]
[% IF matrix_access_token %]
# Pre-mint path: token + device baked in here.
KOAN_MATRIX_ACCESS_TOKEN=[% matrix_access_token %]
[% IF matrix_device_id %]
KOAN_MATRIX_DEVICE_ID=[% matrix_device_id %]
[% END %]
[% ELSE %]
# Bootstrap path: KOAN_MATRIX_ACCESS_TOKEN + KOAN_MATRIX_DEVICE_ID live in
# instance/matrix/credentials.env (written by `app.matrix_login` at first
# provision) and are loaded by the systemd unit via a second EnvironmentFile=.
[% END %]
[% END %]

KOAN_CLI_PROVIDER=[% cli_provider %]
[% IF cli_provider == 'claude' %]
CLAUDE_CODE_OAUTH_TOKEN=[% claude_oauth_token %]
[% END %]

# GitHub bot identity — GH_TOKEN is what the `gh` CLI picks up
# automatically.  GITHUB_USER is read by koan itself for @mention
# matching.
GITHUB_USER=[% github_user %]
GH_TOKEN=[% github_token %]

[% IF smtp_host %]
KOAN_SMTP_HOST=[% smtp_host %]
KOAN_SMTP_PORT=[% smtp_port %]
KOAN_SMTP_USER=[% smtp_user %]
KOAN_SMTP_PASSWORD=[% smtp_password %]
EMAIL_KOAN_OWNER=[% email_to %]
[% END %]
