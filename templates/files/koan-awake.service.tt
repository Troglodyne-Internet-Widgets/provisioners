[Unit]
Description=Kōan messaging bridge ([% domain %])
After=network-online.target
Wants=network-online.target
PartOf=koan.service

[Service]
Type=simple
User=[% user %]
Group=[% user %]
WorkingDirectory=[% install_dir %]/[% domain %]/koan
EnvironmentFile=[% install_dir %]/[% domain %]/.env
EnvironmentFile=-[% install_dir %]/[% domain %]/instance/matrix/credentials.env
Environment=KOAN_ROOT=[% install_dir %]/[% domain %]
Environment=PYTHONPATH=[% install_dir %]/[% domain %]/koan
Environment=PATH=[% install_dir %]/[% domain %]/.venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
Environment=HOME=[% install_dir %]/[% domain %]
ExecStart=[% install_dir %]/[% domain %]/.venv/bin/python app/awake.py
Restart=on-failure
RestartSec=10
StandardOutput=append:[% install_dir %]/[% domain %]/logs/awake.log
StandardError=append:[% install_dir %]/[% domain %]/logs/awake.log

[Install]
WantedBy=multi-user.target
