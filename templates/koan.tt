# Kōan — autonomous coding bot
#
# Layout:
#   [% install_dir %]/[% domain %]            koan checkout root (KOAN_ROOT)
#   [% install_dir %]/[% domain %]/koan/      python package (WorkingDir/PYTHONPATH)
#   [% install_dir %]/[% domain %]/.env       secrets (0640 root:[% user %])
#   [% install_dir %]/[% domain %]/instance/  bot memory/journal/missions (persisted)
#   [% install_dir %]/[% domain %]/.venv      python virtualenv
#   /etc/systemd/system/koan.service          agent loop
#   /etc/systemd/system/koan-awake.service    messaging bridge

# Clone (or refresh) the koan repo into install_dir/domain.  The
# service_user target already owns the dir; we own things back to
# [% user %]:[% admin_user %] after we're done.
if [ ! -d '[% install_dir %]/[% domain %]/.git' ]; then \
    git clone --branch '[% repo_branch %]' '[% repo_url %]' '[% install_dir %]/[% domain %]'; \
else \
    cd '[% install_dir %]/[% domain %]' && git fetch origin && git reset --hard 'origin/[% repo_branch %]'; \
fi
git config --global --get-all safe.directory 2>/dev/null | grep -qFx '[% install_dir %]/[% domain %]' \
    || git config --global --add safe.directory '[% install_dir %]/[% domain %]'

# Stage the gitignored instance/ tree from instance.example (first run only).
# Guarded with `-e "$f"` so an empty instance.example/ doesn't try to cp a literal '*'.
mkdir -p '[% install_dir %]/[% domain %]/instance'
mkdir -p '[% install_dir %]/[% domain %]/logs'
for f in '[% install_dir %]/[% domain %]/instance.example/'*; do \
    [ -e "$$f" ] || continue; \
    name="$$(basename "$$f")"; \
    [ -e "[% install_dir %]/[% domain %]/instance/$$name" ] || cp -r "$$f" "[% install_dir %]/[% domain %]/instance/$$name"; \
done

# Drop in the rendered configs
install -o root -g '[% user %]' -m 0640 koan.env             '[% install_dir %]/[% domain %]/.env'
install -o root -g '[% user %]' -m 0640 koan.config.yaml     '[% install_dir %]/[% domain %]/instance/config.yaml'
install -o root -g '[% user %]' -m 0640 koan.projects.yaml   '[% install_dir %]/[% domain %]/projects.yaml'

# Build the virtualenv as the service user (no shell required for python -m venv)
runuser -u '[% user %]' -- python3 -m venv '[% install_dir %]/[% domain %]/.venv'
runuser -u '[% user %]' -- '[% install_dir %]/[% domain %]/.venv/bin/pip' install --quiet --upgrade pip
runuser -u '[% user %]' -- '[% install_dir %]/[% domain %]/.venv/bin/pip' install --quiet -r '[% install_dir %]/[% domain %]/koan/requirements.txt'

[% IF cli_provider == 'claude' %]
# Install Claude Code CLI globally so the koan user can shell out to `claude`.
# Skip when already on PATH — `npm install -g` round-trips the registry every
# call.  To force an upgrade, uninstall first or run npm update manually.
command -v claude >/dev/null 2>&1 || npm install -g --silent @anthropic-ai/claude-code
[% END %]

[% IF messaging_provider == 'matrix' && matrix_e2ee && matrix_password && !matrix_access_token %]
# Matrix E2EE bootstrap — runs once.  Mints a brand-new device for the bot
# (reusing a device_id silently breaks Megolm), captures the access token,
# writes everything to instance/matrix/credentials.env (0600).  The systemd
# units load that file via a second EnvironmentFile=.
# Re-provisions skip this block because of the `[ ! -f ... ]` guard, so the
# one-shot password never lives on disk and never re-runs.
if [ ! -f '[% install_dir %]/[% domain %]/instance/matrix/credentials.env' ]; then \
    install -d -o '[% user %]' -g '[% user %]' -m 0700 '[% install_dir %]/[% domain %]/instance/matrix'; \
    KOAN_ROOT='[% install_dir %]/[% domain %]' \
    KOAN_MATRIX_HOMESERVER='[% matrix_homeserver %]' \
    KOAN_MATRIX_USER_ID='[% matrix_user_id %]' \
    KOAN_MATRIX_PASSWORD='[% matrix_password %]' \
    KOAN_MATRIX_PICKLE_KEY='[% matrix_pickle_key %]' \
    PYTHONPATH='[% install_dir %]/[% domain %]/koan' \
    runuser -u '[% user %]' -- '[% install_dir %]/[% domain %]/.venv/bin/python' -m app.matrix_login; \
fi
[% END %]

[% IF github_ssh_privkey %]
# Bot SSH identity — paired pubkey is registered on the bot's GitHub
# account both as an Auth key (push) and Signing key (commit verify).
# Lives under ~[% user %]/.ssh and persists across re-provisions because
# install_dir/domain is the koan user's home and on the persistent disk.
install -d -o '[% user %]' -g '[% user %]' -m 0700 '[% install_dir %]/[% domain %]/.ssh'
install -o '[% user %]' -g '[% user %]' -m 0600 koan-ssh-privkey '[% install_dir %]/[% domain %]/.ssh/id_koan'
runuser -u '[% user %]' -- ssh-keygen -y -f '[% install_dir %]/[% domain %]/.ssh/id_koan' > '[% install_dir %]/[% domain %]/.ssh/id_koan.pub'
chown '[% user %]:[% user %]' '[% install_dir %]/[% domain %]/.ssh/id_koan.pub'
chmod 0644 '[% install_dir %]/[% domain %]/.ssh/id_koan.pub'

# Trust github.com host keys non-interactively (skip if already present).
if ! runuser -u '[% user %]' -- ssh-keygen -F github.com -f '[% install_dir %]/[% domain %]/.ssh/known_hosts' >/dev/null 2>&1; then \
    ssh-keyscan -t ed25519,rsa github.com 2>/dev/null >> '[% install_dir %]/[% domain %]/.ssh/known_hosts'; \
    chown '[% user %]:[% user %]' '[% install_dir %]/[% domain %]/.ssh/known_hosts'; \
    chmod 0644 '[% install_dir %]/[% domain %]/.ssh/known_hosts'; \
fi

# ssh_config: pin github.com to the bot key (no ssh-agent dependence)
printf 'Host github.com\n    IdentityFile ~/.ssh/id_koan\n    IdentitiesOnly yes\n' > '[% install_dir %]/[% domain %]/.ssh/config'
chown '[% user %]:[% user %]' '[% install_dir %]/[% domain %]/.ssh/config'
chmod 0644 '[% install_dir %]/[% domain %]/.ssh/config'

# gh CLI: emit SSH remotes so subsequent clones + bot pushes go through
# the key rather than the HTTPS+token path.
runuser -u '[% user %]' -- gh config set git_protocol ssh

# Commit signing with the same key (ssh signature format).  user.name +
# user.email pin commit authorship to the bot identity; allowed_signers
# enables local `git log --show-signature` verification.
runuser -u '[% user %]' -- git config --global user.name        '[% github_user %]'
runuser -u '[% user %]' -- git config --global user.email       '[% koan_email %]'
runuser -u '[% user %]' -- git config --global gpg.format       ssh
runuser -u '[% user %]' -- git config --global user.signingkey  '[% install_dir %]/[% domain %]/.ssh/id_koan.pub'
runuser -u '[% user %]' -- git config --global commit.gpgsign   true
runuser -u '[% user %]' -- git config --global tag.gpgsign      true
install -d -o '[% user %]' -g '[% user %]' -m 0755 '[% install_dir %]/[% domain %]/.config/git'
printf '%s %s\n' '[% koan_email %]' "$$(cat '[% install_dir %]/[% domain %]/.ssh/id_koan.pub')" > '[% install_dir %]/[% domain %]/.config/git/allowed_signers'
chown '[% user %]:[% user %]' '[% install_dir %]/[% domain %]/.config/git/allowed_signers'
runuser -u '[% user %]' -- git config --global gpg.ssh.allowedSignersFile '[% install_dir %]/[% domain %]/.config/git/allowed_signers'
[% END %]

# gh HTTPS credential helper — harmless when SSH is set up (the SSH
# remote URLs take precedence), genuinely needed when it isn't.
GH_TOKEN='[% github_token %]' runuser -u '[% user %]' --preserve-env=GH_TOKEN -- \
    gh auth setup-git -h github.com

# Project repos — clone any project with a github_url to its declared
# path.  Idempotent: `if [ ! -d .git ]` skips on re-provision.  Runs as
# [% user %] so the SSH key + ssh-protocol gh config above take effect;
# parent dir is pre-created koan-owned so the runuser-ed clone can write.
[% FOR pname IN projects.keys().sort() %]
[% p = projects.$pname %]
[% IF p.github_url %]
if [ ! -d '[% p.path %]/.git' ]; then \
    mkdir -p "$$(dirname '[% p.path %]')"; \
    chown '[% user %]:[% user %]' "$$(dirname '[% p.path %]')"; \
    GH_TOKEN='[% github_token %]' runuser -u '[% user %]' --preserve-env=GH_TOKEN -- \
        gh repo clone '[% p.github_url %]' '[% p.path %]'; \
fi
[% END %]
[% END %]

# Reset ownership on everything we just dropped in.  .env and config.yaml
# stay 0640 root:[% user %] (read-only to the bot, invisible to others).
chown -R '[% user %]:[% admin_user %]' '[% install_dir %]/[% domain %]'
chown root:'[% user %]' '[% install_dir %]/[% domain %]/.env' '[% install_dir %]/[% domain %]/instance/config.yaml'
chmod 0640 '[% install_dir %]/[% domain %]/.env' '[% install_dir %]/[% domain %]/instance/config.yaml'
find '[% install_dir %]/[% domain %]/.venv' -type d -exec chmod 0750 {} +

# systemd units
install -o root -g root -m 0644 koan.service       /etc/systemd/system/koan.service
install -o root -g root -m 0644 koan-awake.service /etc/systemd/system/koan-awake.service
systemctl daemon-reload
systemctl enable koan-awake.service
systemctl enable koan.service

# Defer start until everything else has run (cron, nginx, etc.)
[% script_dir %]/queue_postrun_task systemctl start koan.service
